<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">


    <!-- Light theme colors (Material 3 inspired) -->

    <Color x:Key="Color.Primary">#6750A4</Color>
    <Color x:Key="Color.OnPrimary">#FFFFFF</Color>
    <Color x:Key="Color.Background">#FFFBFE</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceVariant">#EADDFF</Color>
    <Color x:Key="Color.OnBackground">#1C1B1F</Color>
    <Color x:Key="Color.Outline">#7A5C91</Color>
    <Color x:Key="Color.SecondaryText">#625B71</Color>

    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.OnPrimary" Color="{StaticResource Color.OnPrimary}" />
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />


</ResourceDictionary>
