<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!-- Dark theme colors (Material 3 inspired) -->
  <Color x:Key="md_sys_color_primary">#B69DF6</Color>
  <Color x:Key="md_sys_color_onprimary">#1C1B1F</Color>
  <Color x:Key="md_sys_color_background">#121212</Color>
  <Color x:Key="md_sys_color_surface">#1E1E1E</Color>
  <Color x:Key="md_sys_color_surface_variant">#2A1F3A</Color>
  <Color x:Key="md_sys_color_onbackground">#EAEAEA</Color>
  <Color x:Key="md_sys_color_outline">#A78BFA</Color>
  <Color x:Key="md_sys_color_secondary">#CFC0E8</Color>

  <SolidColorBrush x:Key="md_sys_brush_primary" Color="{StaticResource md_sys_color_primary}" />
  <SolidColorBrush x:Key="md_sys_brush_onprimary" Color="{StaticResource md_sys_color_onprimary}" />
  <SolidColorBrush x:Key="md_sys_brush_background" Color="{StaticResource md_sys_color_background}" />
  <SolidColorBrush x:Key="md_sys_brush_surface" Color="{StaticResource md_sys_color_surface}" />

  <!-- App-level tokens used across styles - dark variants -->
  <Color x:Key="Primary">#B69DF6</Color>
  <Color x:Key="PrimaryDark">#8F6DD9</Color>
  <Color x:Key="PrimaryDarkText">#EAEAEA</Color>
  <Color x:Key="Secondary">#2A1F3A</Color>
  <Color x:Key="Tertiary">#FFB74D</Color>

  <Color x:Key="White">#FFFFFF</Color>
  <Color x:Key="Black">#000000</Color>
  <Color x:Key="Magenta">#D600AA</Color>
  <Color x:Key="MidnightBlue">#0F0C14</Color>
  <Color x:Key="OffBlack">#121212</Color>
    <Color x:Key="Gray100">#2A2A2A</Color>
  <Color x:Key="Gray200">#333333</Color>
  <Color x:Key="Gray300">#3D3D3D</Color>
  <Color x:Key="Gray400">#525252</Color>
  <Color x:Key="Gray500">#6B6B6B</Color>
  <Color x:Key="Gray600">#8A8A8A</Color>
  <Color x:Key="Gray900">#121212</Color>
  <Color x:Key="Gray950">#0B0B0B</Color>

  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
  <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
  <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
  <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
  <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

  <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
  <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
  <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
  <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
  <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
  <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
  <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
  <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />

</ResourceDictionary>
