<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppointmentScheduler.BookingPage"
             Title="New Appointment"
             BackgroundColor="{AppThemeBinding Light={StaticResource Color.Background}, Dark={StaticResource md_sys_color_background}}">

    <Grid RowDefinitions="*,Auto" Padding="12">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16" Padding="12">
                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" 
                                   IsVisible="{Binding IsLoading}" 
                                   Color="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />

                <!-- Header -->
                <Frame Padding="12" BackgroundColor="{AppThemeBinding Light={StaticResource Color.SurfaceVariant}, Dark={StaticResource md_sys_color_surface_variant}}" CornerRadius="12" BorderColor="Transparent" HasShadow="True">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Book an Appointment" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        <Label Text="Fill in the details below to create a new appointment" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Client Information Section -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Client Information" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Full Name *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                           <Entry Text="{Binding ClientName}" 
                                  Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                               Placeholder="Enter client name"
                               TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}"
                               HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Phone Number *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                           <Entry Text="{Binding PhoneNumber}" 
                               Placeholder="Enter phone number" 
                               Keyboard="Telephone"
                        Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                               TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}"
                               HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email Address *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                           <Entry Text="{Binding Email}" 
                               Placeholder="Enter email address" 
                               Keyboard="Email"
                           Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                               TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}"
                               HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Appointment Details Section -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Appointment Details" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Service Type *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                           <Picker ItemsSource="{Binding ServiceTypes}"
                               SelectedItem="{Binding SelectedServiceType}"
                               SelectedIndex="0"
                                   Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                               Title="Select a service"
                               HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Provider" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                           <Entry Text="{Binding Provider}" 
                               Placeholder="Service provider name (optional)" 
                                  Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                               TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}"
                               HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <Grid RowDefinitions="Auto,Auto" RowSpacing="18">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Appointment Date *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" Margin="0,0,0,4" />
                                <DatePicker Date="{Binding AppointmentDate}" 
                                            Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                                            Format="MMMM d, yyyy" HorizontalOptions="FillAndExpand"
                                            HeightRequest="44" VerticalOptions="Start" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Spacing="6">
                            <Label Text="Start Time *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" Margin="0,0,0,4" />
                            <TimePicker Time="{Binding AppointmentTime}" 
                                            HorizontalOptions="FillAndExpand"
                                            Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                                            HeightRequest="44" VerticalOptions="Start" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Duration *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                        <Picker Title="Select duration" SelectedIndex="1"  
                                Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                                HorizontalOptions="FillAndExpand">
                            <Picker.Items>
                                <x:String>30 minutes</x:String>
                                <x:String>1 hour</x:String>
                                <x:String>1.5 hours</x:String>
                                <x:String>2 hours</x:String>
                                <x:String>2.5 hours</x:String>
                                <x:String>3 hours</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Additional Information Section -->
                <VerticalStackLayout Spacing="10">
                        <Label Text="Additional Information" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Cost" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                        <Entry Text="{Binding Cost}" Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}" Placeholder="0.00" Keyboard="Numeric"  TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Status *" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                        <Picker ItemsSource="{Binding Statuses}" Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}" SelectedItem="{Binding SelectedStatus}" Title="Select status"  HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Notes" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                        <Editor Text="{Binding Notes}" Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}" Placeholder="Additional notes or special requests (optional)" HeightRequest="80"  HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <HorizontalStackLayout Grid.Row="1" Spacing="12" Padding="8">
            <Button Text="Book Appointment" Command="{Binding BookCommand}" FontSize="14" Padding="16,10" CornerRadius="12" BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}" HorizontalOptions="FillAndExpand" Margin="0,6" />
            <Button Text="Cancel" Command="{Binding CancelCommand}" FontSize="14" Padding="16,10" CornerRadius="12" BackgroundColor="{AppThemeBinding Light={StaticResource Color.SurfaceVariant}, Dark={StaticResource md_sys_color_surface_variant}}" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" HorizontalOptions="FillAndExpand" Margin="0,6" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
