<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppointmentScheduler"
              xmlns:syncTheme="clr-namespace:Syncfusion.Maui.Themes;assembly=Syncfusion.Maui.Core"
             UserAppTheme="Light"
             x:Class="AppointmentScheduler.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Common tokens / brushes -->
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <!-- App styles that reference md_sys_* tokens -->
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <!-- Theme dictionary is loaded dynamically in App.xaml.cs -->
                <syncTheme:SyncfusionThemeResourceDictionary VisualTheme="MaterialLight"/>
                    <!-- Provide a default theme at design/build time so StaticResource lookups succeed -->
                    <ResourceDictionary Source="Resources/Styles/Theme.Light.xaml" />
                    <ResourceDictionary Source="Resources/Styles/Theme.Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
