<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppointmentScheduler.AppointmentDetailsPage"
             Title="Appointment Details">
    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="Android" Value="10,20,10,10" />
            <On Platform="iOS,MacCatalyst,Windows" Value="10" />
        </OnPlatform>
    </ContentPage.Padding>

    <Grid RowDefinitions="*,Auto" Padding="6">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12" Padding="6">
                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" 
                                 IsVisible="{Binding IsLoading}" 
                                 Color="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />

                <VerticalStackLayout Spacing="12">
                    <!-- Appointment Date and Time -->
                    <Frame Padding="10" BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource md_sys_color_surface}}" CornerRadius="8" BorderColor="Transparent" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Date &amp; Time" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                            <Label Text="{Binding Appointment.Start, StringFormat='{0:MMMM d, yyyy}'}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                            <Label Text="{Binding Appointment.TimeSlot}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Client Information -->
                    <VerticalStackLayout Spacing="8">

                        <Label Text="Client Information" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />

                        <VerticalStackLayout Spacing="4">
                                    <Label Text="Name" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                                    <Entry Text="{Binding Appointment.ClientName}" 
                                        Placeholder="Client Name"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                        TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                                    <Label Text="Phone" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                                    <Entry Text="{Binding Appointment.PhoneNumber}" 
                                        Placeholder="Phone Number" 
                                        Keyboard="Telephone"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                        TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                                    <Label Text="Email" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                                    <Entry Text="{Binding Appointment.Email}" 
                                        Placeholder="Email Address" 
                                        Keyboard="Email"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                        TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Service Information -->
                    <VerticalStackLayout Spacing="8">

                        <Label Text="Service Information" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />

                        <VerticalStackLayout Spacing="4">
                                                                <Label Text="Service Type" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                                                        <Entry Text="{Binding Appointment.ServiceType}" 
                                                                    Placeholder="Service Type"
                                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                                                    TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                                                                <Label Text="Provider" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                                                        <Entry Text="{Binding Appointment.Provider}" 
                                                                    Placeholder="Service Provider"
                                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                                                    TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Status" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                            <Picker SelectedItem="{Binding Appointment.Status}" 
                                   Title="Select Status" SelectedIndex="0"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                   TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}">
                                <Picker.Items>
                                    <x:String>Pending</x:String>
                                    <x:String>Scheduled</x:String>
                                    <x:String>Confirmed</x:String>
                                </Picker.Items>
                            </Picker>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                                                                <Label Text="Cost" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                                                        <Entry Text="{Binding Appointment.Cost}" 
                                                                    Placeholder="0.00" 
                                                                    Keyboard="Numeric"
                                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                                                                    TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Notes -->
                    <VerticalStackLayout Spacing="4">
                           <Label Text="Notes" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource md_sys_color_secondary}}" />
                           <Editor Text="{Binding Appointment.Notes}" 
                               Placeholder="Additional notes" 
                               HeightRequest="100"
                               BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource Gray500}}"
                               TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Buttons -->
             <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="6">
             <Button Text="Save" 
                 Command="{Binding SaveCommand}" 
                 FontSize="14"
                 Padding="20,10"
                 CornerRadius="8"
                 BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}"
                 TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}"
                 HorizontalOptions="FillAndExpand" />
             <Button Text="Delete" 
                 Command="{Binding DeleteCommand}" 
                 FontSize="14"
                 Padding="20,10"
                 CornerRadius="8"
                 BackgroundColor="{AppThemeBinding Light={StaticResource Color.Outline}, Dark={StaticResource md_sys_color_outline}}"
                 TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}"
                 HorizontalOptions="FillAndExpand" />
             <Button Text="Cancel" 
                 Command="{Binding CancelCommand}" 
                 FontSize="14"
                 Padding="20,10"
                 CornerRadius="8"
                 BackgroundColor="{AppThemeBinding Light={StaticResource Color.SurfaceVariant}, Dark={StaticResource md_sys_color_surface_variant}}"
                 TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}"
                 HorizontalOptions="FillAndExpand" />
         </HorizontalStackLayout>
    </Grid>
</ContentPage>
