<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppointmentScheduler.RootPage"
             Title="Appointment Scheduler"
             
             BackgroundColor="{AppThemeBinding 
                                Light={StaticResource Color.Background},
                                Dark={StaticResource md_sys_color_background}}"
>

    <!-- Use application-level theme resources instead of page-local colors -->

    <Grid x:Name="RootGrid" ColumnDefinitions="250, *" RowDefinitions="*">
        <!-- Left navigation panel -->
        <StackLayout x:Name="NavPanel" 
    BackgroundColor="{AppThemeBinding 
                        Light={StaticResource Color.SurfaceVariant},
                        Dark={StaticResource md_sys_color_surface_variant}}"
            Padding="16" Spacing="16">
            <Label Text="Appointment Scheduler" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}" FontSize="18" />

            <VerticalStackLayout Spacing="8">
                <Button x:Name="BtnAppointments"
                    Text="Appointments"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}"
                    TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}"
                    CornerRadius="12"
                    Clicked="OnAppointmentsClicked" />

                <Button x:Name="BtnNewBooking"
                        Text="New Booking"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground},Dark=White}"
                        CornerRadius="12"
                        Clicked="OnNewBookingClicked" />

                <!-- ✅ NEW TAB -->
                <Button x:Name="BtnUpcoming"
                    BackgroundColor="Transparent"
                    Text="Upcoming Appointments"
                    CornerRadius="12"
                    HeightRequest="50"
                    TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground},Dark=White}"
                    Clicked="OnUpcomingClicked" />
            </VerticalStackLayout>

            <BoxView VerticalOptions="EndAndExpand" HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource Color.Outline}, Dark={StaticResource md_sys_color_outline}}" />
        </StackLayout>

        <!-- Right content area - we'll inject page Content here -->
        <Frame Grid.Column="1" 
    BackgroundColor="{AppThemeBinding 
                      Light={StaticResource Color.Surface},
                      Dark={StaticResource md_sys_color_surface}}"
 CornerRadius="12" Padding="12" HasShadow="False">
            <ContentView x:Name="ContentHost" />
        </Frame>

    </Grid>
</ContentPage>