<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             xmlns:popups="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
             x:Class="AppointmentScheduler.MainPage"
            
             Title="Appointment Scheduler"
             BackgroundColor="{AppThemeBinding Light={StaticResource Color.Background}, Dark={StaticResource md_sys_color_background}}">
    <!-- Use application-level theme resources instead of page-local colors -->
    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="Android" Value="10,20,10,10" />
            <On Platform="iOS,MacCatalyst,Windows" Value="10" />
        </OnPlatform>
    </ContentPage.Padding>

    <Grid x:Name="Root" Padding="6" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,Auto"  RowSpacing="8">
        <!-- Header (row 0) -->
        <Border Grid.Column="2" HeightRequest="44" WidthRequest="44" Stroke="#00000000"
        BackgroundColor="{AppThemeBinding Light={StaticResource Color.SurfaceVariant}, Dark={StaticResource Gray600}}"
        HorizontalOptions="End" VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Label x:Name="ThemeToggleButton"  FontFamily="MauiMaterialAssets" FontSize="18"
           HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource md_sys_color_onbackground}}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="ThemeToggleButton_Clicked" />
                </Label.GestureRecognizers>
            </Label>
        </Border>
        <Frame Grid.Row="1" Padding="10" Grid.ColumnSpan="2" BackgroundColor="{AppThemeBinding Light={StaticResource Color.SurfaceVariant}, Dark=#5B566B}" CornerRadius="8" BorderColor="Transparent" HasShadow="False">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="8" Grid.Column="0">
                    <Label Text="Appointments" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />
                    <HorizontalStackLayout Spacing="20" Margin="0,10,0,0">
                        <VerticalStackLayout HorizontalOptions="FillAndExpand" Spacing="4">
                            <Label Text="Total Appointments" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />
                            <Label Text="{Binding TotalAppointmentsCount}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource Tertiary}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout HorizontalOptions="FillAndExpand" Spacing="4">
                            <Label Text="Confirmed" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />
                            <Label Text="{Binding ConfirmedCount}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource Tertiary}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout HorizontalOptions="FillAndExpand" Spacing="4">
                            <Label Text="Pending" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" />
                            <Label Text="{Binding PendingCount}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark={StaticResource Tertiary}}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Month label / small calendar control on the right to match layout -->
                <Grid Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center">
                    <Label Text="June 2026" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}" VerticalOptions="Center" HorizontalOptions="End" />
                </Grid>
            </Grid>
        </Frame>

        <!-- Controls (row 1) -->
        <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
            <Label Text="Select Date &amp; Filter" FontSize="16" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                  <DatePicker Date="{Binding SelectedDate, Mode=TwoWay}" 
                               Background="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                           HorizontalOptions="FillAndExpand" 
                           MinimumWidthRequest="150" />
                  <Button Text="Today"  WidthRequest="{OnPlatform Android=70, WinUI=110, iOS=70,MacCatalyst=120}"
                      Command="{Binding TodayCommand}" 
                      Padding="8,4"
                      FontSize="12"
                      CornerRadius="6"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}"
                      TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}" />
                <Button Text="Filter" WidthRequest="{OnPlatform Android=70, WinUI=110, iOS=70,MacCatalyst=120}"
                      Command="{Binding FilterCommand}"
                      Padding="8,4"
                      FontSize="12"
                      CornerRadius="6"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}"
                     TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}" />
                <Button Text="Refresh" WidthRequest="{OnPlatform Android=70, WinUI=110, iOS=70,MacCatalyst=120}"
                       Command="{Binding RefreshCommand}" 
                       Padding="8,4"
                       FontSize="12"
                       CornerRadius="6"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}"
                      TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>


        <!-- DataGrid area (row 3) -->
        <Grid Grid.Row="3" Grid.ColumnSpan="2">
                 <Frame Padding="0"
                     CornerRadius="12"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource md_sys_color_surface}}"
                     BorderColor="{AppThemeBinding Light={StaticResource Color.Outline}, Dark={StaticResource Gray600}}"
                     HasShadow="False"
                     HorizontalOptions="FillAndExpand"
                     VerticalOptions="FillAndExpand">

                  <syncfusion:SfDataGrid x:Name="AppointmentsGrid"
                       ItemsSource="{Binding AllAppointments}"
                       AutoGenerateColumnsMode="None"
                       ColumnWidthMode="{OnPlatform Android=Auto,WinUI=Fill,MacCatalyst=Fill,iOS=Auto}"
                       RowHeight="55"
                       HeaderRowHeight="65"
                                       FooterFrozenColumnCount="1"
                       SelectionMode="Single"
                       HorizontalOptions="FillAndExpand"
                       VerticalOptions="FillAndExpand">

                    <syncfusion:SfDataGrid.DefaultStyle>
                        <syncfusion:DataGridStyle
                            RowTextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource White}}"
                            HeaderRowTextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark={StaticResource White}}"
                            HeaderRowBackground="{AppThemeBinding Light={StaticResource Color.SurfaceVariant}, Dark=#5B566B}"
                            RowBackground="{AppThemeBinding Light={StaticResource Color.Surface}, Dark={StaticResource md_sys_color_surface}}"
                            GridLineColor="{AppThemeBinding Light={StaticResource Color.Outline}, Dark={StaticResource Gray600}}" />
                    </syncfusion:SfDataGrid.DefaultStyle>

                    <syncfusion:SfDataGrid.Columns>

                        <syncfusion:DataGridDateColumn MappingName="Start"
                                       HeaderText="Date"
                                       Format="MMM d, yyyy" />

                        <syncfusion:DataGridTextColumn MappingName="TimeSlot"
                                       HeaderText="Time" />

                        <syncfusion:DataGridTextColumn MappingName="ClientName"
                                       HeaderText="Client" />

                        <syncfusion:DataGridTextColumn MappingName="ServiceType"
                                       HeaderText="Service" />

                        <syncfusion:DataGridTextColumn MappingName="Status"
                                       HeaderText="Status" />

                        <syncfusion:DataGridTemplateColumn HeaderText="Reschedule" Width="{OnPlatform Android=110, WinUI=120}">
                            <syncfusion:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                            <Button Text="Reschedule"
                                            WidthRequest="{OnPlatform Android=80, WinUI=90}"
                                            MinimumWidthRequest="70"
                                            HeightRequest="{OnPlatform Android=28, WinUI=32}"
                                            FontSize="12"
                                            CornerRadius="8"
                                            Padding="6,4"
                                            HorizontalOptions="CenterAndExpand"
                                            VerticalOptions="Center"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Color.Primary}, Dark={StaticResource md_sys_color_primary}}"
                                            TextColor="{AppThemeBinding Light={StaticResource Color.OnPrimary}, Dark={StaticResource md_sys_color_onprimary}}"
                                            Clicked="OnRescheduleRowClicked" />
                                </DataTemplate>
                            </syncfusion:DataGridTemplateColumn.CellTemplate>
                        </syncfusion:DataGridTemplateColumn>

                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>
            </Frame>
        </Grid>

        <!-- Reschedule overlay (fills page to dim background and block input) -->
        <!-- ✅ Reschedule overlay -->
        <Grid x:Name="ReschedulePopup"
      IsVisible="False"
      Grid.Row="0"
      Grid.ColumnSpan="2"
      Grid.RowSpan="5"
      HorizontalOptions="FillAndExpand"
      VerticalOptions="FillAndExpand"
      InputTransparent="False">

            <!-- ✅ Dark overlay -->
            <Grid.Background>
                <SolidColorBrush Color="#80000000" />
            </Grid.Background>

            <!-- ✅ Popup Card -->
            <Frame Padding="20"
           CornerRadius="16"
           HasShadow="True"
           WidthRequest="360"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           BackgroundColor="{AppThemeBinding 
                                Light={StaticResource Color.SurfaceVariant}, 
                                Dark=#2E2440}">

                <VerticalStackLayout Spacing="16">

                    <!-- ✅ Title -->
                    <Label Text="Reschedule Appointment"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="{AppThemeBinding 
                                Light={StaticResource Color.OnBackground}, 
                                Dark=White}" />

                    <!-- ✅ DATE -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Date"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark=#D1CFE2}" />

                        <DatePicker x:Name="PopupDatePicker"
                            HeightRequest="44"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                            TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark=White}" />
                    </VerticalStackLayout>

                    <!-- ✅ TIME -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Time"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Color.SecondaryText}, Dark=#D1CFE2}" />

                        <TimePicker x:Name="PopupTimePicker"
                            HeightRequest="44"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Color.Surface}, Dark=#5B566B}"
                            TextColor="{AppThemeBinding Light={StaticResource Color.OnBackground}, Dark=White}" />
                    </VerticalStackLayout>

                    <!-- ✅ ACTION BUTTONS -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">

                        <!-- Cancel -->
                        <Button Text="Cancel" Clicked="OnPopupCancelClicked" 
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                FontSize="14"
                                Padding="10,8"
                                CornerRadius="10"
                                BorderWidth="1"
                                BorderColor="{AppThemeBinding  Light={StaticResource Color.Primary}, Dark=#B69DF6}"
                                WidthRequest="150"
                                HeightRequest="44"
                                HorizontalOptions="Start"
                                TextColor="{AppThemeBinding 
                                    Light={StaticResource Color.Primary}, 
                                    Dark=#B69DF6}" />

                        <!-- Save -->
                        <Button Text="Save"
                            Clicked="OnPopupSaveClicked" 
                            Grid.Column="1"
                            FontSize="14"
                            Padding="16,8"
                            CornerRadius="10"
                            WidthRequest="150"
                            HeightRequest="44"
                            HorizontalOptions="End"
                            BackgroundColor="{AppThemeBinding 
                                        Light={StaticResource Color.Primary}, 
                                        Dark=#B69DF6}"
                            TextColor="{AppThemeBinding 
                                    Light={StaticResource Color.OnPrimary}, 
                                    Dark=#1C1B1F}" />

                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </Grid>


    </Grid>
</ContentPage>
